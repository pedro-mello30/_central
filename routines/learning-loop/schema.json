{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["date", "proposals"],
  "additionalProperties": false,
  "properties": {
    "date": { "type": "string", "minLength": 1 },
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["op"],
        "properties": {
          "op": { "type": "string", "enum": ["add", "transition", "correct", "task", "reindex"] },
          "record": {
            "type": "object",
            "required": ["kind", "status", "text", "origin"],
            "properties": {
              "kind": { "type": "string", "enum": ["learning", "hypothesis", "decision"] },
              "status": { "type": "string", "minLength": 1 },
              "text": { "type": "string", "minLength": 1 },
              "origin": { "type": "string", "minLength": 1 }
            }
          },
          "id": { "type": "string" },
          "to": { "type": "string" },
          "text": { "type": "string" },
          "reason": { "type": "string" },
          "title": { "type": "string" },
          "origin": { "type": "string" },
          "target": { "type": "string" }
        },
        "allOf": [
          {
            "if": { "properties": { "op": { "const": "add" } } },
            "then": { "required": ["record"] }
          },
          {
            "if": { "properties": { "op": { "const": "task" } } },
            "then": { "required": ["title", "origin", "target"] }
          }
        ]
      }
    }
  }
}
