{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["date", "queue", "top5", "drafts", "problems"],
  "additionalProperties": false,
  "properties": {
    "date": { "type": "string", "minLength": 1 },
    "queue": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task", "status", "signal"],
        "additionalProperties": false,
        "properties": {
          "task": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["open", "overdue", "unowned", "at_risk"] },
          "signal": { "type": "string", "minLength": 1 }
        }
      }
    },
    "top5": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["task", "reason", "decision"],
        "additionalProperties": false,
        "properties": {
          "task": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "decision": { "type": "string", "minLength": 1 }
        }
      }
    },
    "drafts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task", "comment"],
        "additionalProperties": false,
        "properties": {
          "task": { "type": "string", "minLength": 1 },
          "comment": { "type": "string", "minLength": 1 }
        }
      }
    },
    "problems": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
