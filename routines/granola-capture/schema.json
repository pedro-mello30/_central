{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["date", "captured"],
  "additionalProperties": false,
  "properties": {
    "date": { "type": "string", "minLength": 1 },
    "captured": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "text", "origin"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["objection", "discovery", "follow_up", "decision_mentioned"]
          },
          "text": { "type": "string", "minLength": 1 },
          "origin": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
