{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["week_of", "wins", "metrics", "misses", "focus_next_week", "risks"],
  "additionalProperties": false,
  "properties": {
    "week_of": { "type": "string", "minLength": 1 },
    "wins": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "value", "delta"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "value": { "type": "string", "minLength": 1 },
          "delta": { "type": "string", "minLength": 1 }
        }
      }
    },
    "misses": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "focus_next_week": {
      "type": "array",
      "maxItems": 3,
      "items": { "type": "string", "minLength": 1 }
    },
    "risks": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
