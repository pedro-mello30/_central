{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["week_of", "proposals"],
  "additionalProperties": false,
  "properties": {
    "week_of": { "type": "string", "minLength": 1 },
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["op", "id", "reason"],
        "additionalProperties": false,
        "properties": {
          "op": { "type": "string", "enum": ["transition", "correct"] },
          "id": { "type": "string", "minLength": 1 },
          "to": { "type": "string" },
          "text": { "type": "string" },
          "reason": { "type": "string", "minLength": 1 }
        },
        "allOf": [
          {
            "if": { "properties": { "op": { "const": "transition" } } },
            "then": { "required": ["to"] }
          },
          {
            "if": { "properties": { "op": { "const": "correct" } } },
            "then": { "required": ["text"] }
          }
        ]
      }
    }
  }
}
